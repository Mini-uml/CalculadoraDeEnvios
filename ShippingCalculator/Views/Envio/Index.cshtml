@model ShippingCalculator.Models.Envio

@{
    Layout = null; 
}

<!DOCTYPE html>
<html>
<head>
    <title>Calculadora de Envío</title>

    <style>
        body {
            font-family: Arial, sans-serif;
            background: linear-gradient(to right, #d7ccc8, #f5f5f5);
            display: flex;
            justify-content: center;
            align-items: center;
            height: 100vh;
            margin: 0;
        }

        .contenedor {
            background: #ffffff;
            padding: 30px;
            border-radius: 15px;
            box-shadow: 0px 6px 20px rgba(0,0,0,0.15);
            width: 350px;
            text-align: center;
        }

        h2 {
            color: #5a3e2b;
            margin-bottom: 20px;
        }

        label {
            display: block;
            text-align: left;
            margin-top: 10px;
            font-weight: bold;
            color: #333;
        }

        input, select {
            width: 100%;
            padding: 10px;
            margin-top: 5px;
            border-radius: 8px;
            border: 1px solid #ccc;
            outline: none;
        }

            input:focus, select:focus {
                border-color: #8b5e3c;
            }

        button {
            margin-top: 20px;
            width: 100%;
            padding: 12px;
            background: #8b5e3c;
            color: white;
            border: none;
            border-radius: 10px;
            cursor: pointer;
            font-size: 16px;
            transition: 0.3s;
        }

            button:hover {
                background: #6f4a2d;
            }

        .resultado {
            margin-top: 20px;
            font-size: 18px;
            color: #5a3e2b;
            font-weight: bold;
        }

        .error {
            color: red;
            margin-top: 10px;
        }
    </style>
</head>

<body>

    <div class="contenedor">

        <h2>Calculadora de Envío</h2>

        <form method="post" asp-action="Calcular">

            <label>Peso del paquete:</label>
            <input type="number" step="0.1" name="Peso" value="@Model?.Peso" required />

            <label>País de destino:</label>
            <select name="Pais">

                @if (Model?.Pais == "India")
                {
                    <option value="India" selected>India</option>
                }
                else
                {
                    <option value="India">India</option>
                }

                @if (Model?.Pais == "US")
                {
                    <option value="US" selected>Estados Unidos</option>
                }
                else
                {
                    <option value="US">Estados Unidos</option>
                }

                @if (Model?.Pais == "UK")
                {
                    <option value="UK" selected>Reino Unido</option>
                }
                else
                {
                    <option value="UK">Reino Unido</option>
                }

            </select>

            <button type="submit">Calcular</button>
        </form>

        @if (ViewBag.Error != null)
        {
            <p class="error">@ViewBag.Error</p>
        }

        @if (Model != null && Model.Costo > 0)
        {
            <p class="resultado">Costo de envío: $@Model.Costo USD</p>
        }

    </div>

</body>
</html>